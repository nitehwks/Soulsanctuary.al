# SoulSanctuary Environment Variables
# Copy this file to .env.local and fill in real values before building or running.

# Backend server port (defaults to 5001)
PORT=5001

# PostgreSQL database connection string
DATABASE_URL=postgresql://user:password@host:port/soulsanctuary

# Clerk authentication (https://dashboard.clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_SIGN_IN_URL=/sign-in
CLERK_SIGN_UP_URL=/sign-up

# OpenRouter AI configuration
AI_INTEGRATIONS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_INTEGRATIONS_OPENROUTER_API_KEY=your-openrouter-api-key

# Mobile client backend URL
# Set this to the public URL where the Express backend is deployed.
# Example local dev: http://192.168.1.100:5001
# Example production: https://soulsanctuary.app
VITE_API_URL=https://soulsanctuary.app
